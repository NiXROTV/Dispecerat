<Window x:Class="EvidentaFlota_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Management Flotă" Height="680" Width="1000" MinWidth="750" MinHeight="520"
        Background="#1E1E2E">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Margin" Value="0,4,0,1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="#313150"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="CaretBrush" Value="#A78BFA"/>
            <Setter Property="BorderBrush" Value="#4C4C7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6D28D9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#A78BFA"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="BorderBrush" Value="#4C4C7A"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3D3D60"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="RowBackground" Value="#2A2A3E"/>
            <Setter Property="AlternatingRowBackground" Value="#313150"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#5B21B6"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4C1D95"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== MENIU ===== -->
        <Menu Grid.Row="0" Background="#2A2A3E" BorderBrush="#3D3D60" BorderThickness="0,0,0,1" Padding="6,4">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#CBD5E1"/>
                    <Setter Property="Background" Value="#2A2A3E"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                </Style>
            </Menu.Resources>
            <MenuItem Header="_Aplicație">
                <MenuItem Header="_Ieșire" Click="MenuItemIesire_Click"/>
            </MenuItem>
            <MenuItem Header="_Camioane">
                <MenuItem Header="_Adăugare Camion" Click="MenuItemAdaugare_Click"/>
                <MenuItem Header="_Modificare Camion" Click="MenuItemModifica_Click"/>
            </MenuItem>
            <MenuItem Header="_Șoferi">
                <MenuItem Header="_Gestionare Șoferi" Click="MenuItemSoferi_Click"/>
            </MenuItem>
            <MenuItem Header="_Curse">
                <MenuItem Header="_Gestionare Curse" Click="MenuItemCurse_Click"/>
            </MenuItem>
            <MenuItem Header="_Ajutor">
                <MenuItem Header="_Despre" Click="MenuItemDespre_Click"/>
            </MenuItem>
        </Menu>

        <!-- ===== ZONA CONTINUT ===== -->
        <Grid Grid.Row="1" Margin="15">

            <!-- ══════════════════════════════════════════════
                 PANEL 1: ADĂUGARE CAMION + DATAGRID
                 ══════════════════════════════════════════════ -->
            <Grid x:Name="paneluAdaugare" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330" MinWidth="250"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Form adaugare -->
                <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="12" Padding="16">
                    <Border.Effect><DropShadowEffect BlurRadius="18" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Adăugare Camion" FontSize="17" FontWeight="Bold"
                                       Foreground="#F1F5F9" Margin="0,0,0,12"/>

                            <Label x:Name="lblNumar" Content="Număr Înmatriculare:"/>
                            <TextBox x:Name="txtNumar"/>

                            <Label x:Name="lblMarca" Content="Marcă:"/>
                            <TextBox x:Name="txtMarca"/>

                            <Label x:Name="lblCapacitate" Content="Capacitate (Tone):"/>
                            <TextBox x:Name="txtCapacitate"/>

                            <Label Content="Data Înregistrării:"/>
                            <DatePicker x:Name="dpDataInregistrarii"/>

                            <!-- ListBox TipContract - valori predefinite, selectie unica -->
                            <GroupBox Header="Tip Contract">
                                <ListBox x:Name="lstTipContract" Height="65"
                                         SelectionMode="Single" BorderThickness="0" Margin="4"/>
                            </GroupBox>

                            <GroupBox Header="Status Curent">
                                <StackPanel Margin="4">
                                    <RadioButton x:Name="rbDisponibil" Content="Disponibil" IsChecked="True" Margin="0,2"/>
                                    <RadioButton x:Name="rbInCursa" Content="În Cursă" Margin="0,2"/>
                                    <RadioButton x:Name="rbInService" Content="În Service" Margin="0,2"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Dotări Opționale">
                                <StackPanel Margin="4">
                                    <CheckBox x:Name="chkAer" Content="Aer Condiționat" Margin="0,2"/>
                                    <CheckBox x:Name="chkNavigatie" Content="Navigație" Margin="0,2"/>
                                    <CheckBox x:Name="chkFrig" Content="Sistem Frig" Margin="0,2"/>
                                    <CheckBox x:Name="chkDormitor" Content="Dormitor" Margin="0,2"/>
                                </StackPanel>
                            </GroupBox>

                            <TextBlock x:Name="lblMesaj" TextWrapping="Wrap"
                                       Margin="0,4" FontWeight="SemiBold"/>
                            <Button Content="➕  Adaugă Camion" Click="BtnAdauga_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- DataGrid camioane + binding pentru numar -->
                <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="12" Padding="16">
                    <Border.Effect><DropShadowEffect BlurRadius="18" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="Listă Camioane" FontSize="17" FontWeight="Bold"
                                       Foreground="#F1F5F9" Margin="0,0,0,6"/>
                            <Label Content="{Binding ElementName=dgCamioane,
                                                     Path=Items.Count,
                                                     StringFormat='Număr camioane: {0}'}"
                                   FontWeight="Bold" Foreground="#2980B9" Margin="0"/>
                        </StackPanel>
                        <DataGrid x:Name="dgCamioane" DockPanel.Dock="Top">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nr. Înmatriculare" Binding="{Binding NumarInmatriculare}" Width="130"/>
                                <DataGridTextColumn Header="Marcă" Binding="{Binding Marca}" Width="100"/>
                                <DataGridTextColumn Header="Cap. (t)" Binding="{Binding CapacitateTone}" Width="65"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusCurent}" Width="90"/>
                                <DataGridTextColumn Header="Tip Contract" Binding="{Binding TipContract}" Width="90"/>
                                <DataGridTextColumn Header="Data Înreg." Binding="{Binding DataInregistrarii, StringFormat=dd/MM/yyyy}" Width="85"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════
                 PANEL 2: MODIFICARE CAMION cu TwoWay Binding
                 ══════════════════════════════════════════════ -->
            <Grid x:Name="panelModificare" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" MinWidth="240"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Selectie camion -->
                <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="12" Padding="16">
                    <Border.Effect><DropShadowEffect BlurRadius="18" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Modificare Camion" FontSize="17" FontWeight="Bold"
                                   Foreground="#F1F5F9" Margin="0,0,0,12"/>
                        <Label Content="Selectează Camionul:"/>
                        <ComboBox x:Name="cmbCamioane"
                                  DisplayMemberPath="NumarInmatriculare"
                                  SelectionChanged="CmbCamioane_SelectionChanged"/>

                        <TextBlock x:Name="lblMesajMod" TextWrapping="Wrap"
                                   Margin="0,6" FontWeight="SemiBold"/>

                        <Button Content="💾  Actualizează" Click="BtnActualizeaza_Click"
                                Background="#27AE60"/>
                        <Button Content="◀  Înapoi la Listă" Click="MenuItemAdaugare_Click"
                                Background="#95A5A6" Margin="0,4"/>
                    </StackPanel>
                </Border>

                <Border x:Name="borderDetaliiMod" Grid.Column="2" Background="White"
                        CornerRadius="10" Padding="14">
                    <Border.Effect><DropShadowEffect BlurRadius="18" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Câmpuri de Editat" FontSize="15" FontWeight="Bold"
                                       Foreground="#F1F5F9" Margin="0,0,0,10"/>

                            <Label Content="Număr Înmatriculare (read-only):"/>
                            <TextBox Text="{Binding NumarInmatriculare, Mode=OneWay}"
                                     IsReadOnly="True" Background="#ECF0F1"/>

                            <Label x:Name="lblModMarca" Content="Marcă:"/>
                            <TextBox Text="{Binding Marca, Mode=TwoWay,
                                                    UpdateSourceTrigger=PropertyChanged}"/>

                            <Label x:Name="lblModCapacitate" Content="Capacitate (Tone):"/>
                            <TextBox Text="{Binding CapacitateTone, Mode=TwoWay,
                                                    UpdateSourceTrigger=PropertyChanged,
                                                    StringFormat='{}{0:F2}'}"/>

                            <Label Content="Data Înregistrării:"/>
                            <DatePicker SelectedDate="{Binding DataInregistrarii, Mode=TwoWay}"/>

                            <Label Content="Tip Contract:"/>
                            <ComboBox x:Name="cmbModTipContract"
                                      SelectedItem="{Binding TipContract, Mode=TwoWay}"/>

                            <Label Content="Status Curent:"/>
                            <ComboBox x:Name="cmbModStatus"
                                      SelectedItem="{Binding StatusCurent, Mode=TwoWay}"/>

                            <GroupBox Header="Dotări (selectie multiplă)">
                                <ListBox x:Name="lstModDotari" SelectionMode="Multiple"
                                         Height="95" BorderThickness="0" Margin="4">
                                    <ListBoxItem Content="Aer Condiționat" Tag="AerConditionat"/>
                                    <ListBoxItem Content="Navigație" Tag="Navigatie"/>
                                    <ListBoxItem Content="Sistem Frig" Tag="SistemFrig"/>
                                    <ListBoxItem Content="Dormitor" Tag="Dormitor"/>
                                </ListBox>
                            </GroupBox>

                            <TextBlock Text="Ultima Actualizare:" FontWeight="Bold"
                                       Foreground="#7F8C8D" Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding DataActualizarii,
                                                      StringFormat='dd/MM/yyyy HH:mm',
                                                      Mode=OneWay}"
                                       Foreground="#7F8C8D"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════
                 PANEL 3: CRUD ȘOFERI
                 ══════════════════════════════════════════════ -->
            <Grid x:Name="panelSoferi" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310" MinWidth="240"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="12" Padding="16">
                    <Border.Effect><DropShadowEffect BlurRadius="18" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Gestionare Șoferi" FontSize="17" FontWeight="Bold"
                                       Foreground="#F1F5F9" Margin="0,0,0,12"/>

                            <Label Content="ID Angajat:"/>
                            <TextBox x:Name="txtSoferId"/>

                            <Label x:Name="lblSoferNume" Content="Nume:"/>
                            <TextBox x:Name="txtSoferNume"/>

                            <Label x:Name="lblSoferPrenume" Content="Prenume:"/>
                            <TextBox x:Name="txtSoferPrenume"
                                     Text="{Binding Prenume, Mode=TwoWay,
                                                    UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Content="Status:"/>
                            <ComboBox x:Name="cmbSoferStatus"
                                      SelectedItem="{Binding StatusCurent, Mode=TwoWay}"/>

                            <GroupBox Header="Atestate">
                                <StackPanel Margin="4">
                                    <CheckBox x:Name="chkMarfaGen" Content="Marfă Generală" Margin="0,2"/>
                                    <CheckBox x:Name="chkADR" Content="ADR" Margin="0,2"/>
                                    <CheckBox x:Name="chkAgabaritic" Content="Agabaritic" Margin="0,2"/>
                                    <CheckBox x:Name="chkFrigorific" Content="Frigorific" Margin="0,2"/>
                                </StackPanel>
                            </GroupBox>

                            <TextBlock x:Name="lblMesajSofer" TextWrapping="Wrap"
                                       Margin="0,4" FontWeight="SemiBold"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="➕ Adaugă" Click="BtnAdaugaSofer_Click"/>
                                <Button Grid.Column="2" Content="💾 Actualizează" Click="BtnActualizeazaSofer_Click"
                                        Background="#27AE60"/>
                            </Grid>
                            <Button Content="🗑 Șterge Selectat" Click="BtnStergeSofer_Click"
                                    Background="#E74C3C"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="12" Padding="16">
                    <Border.Effect><DropShadowEffect BlurRadius="18" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="Listă Șoferi" FontSize="17" FontWeight="Bold"
                                       Foreground="#F1F5F9" Margin="0,0,0,6"/>
                            <Label Content="{Binding ElementName=dgSoferi,
                                                     Path=Items.Count,
                                                     StringFormat='Număr șoferi: {0}'}"
                                   FontWeight="Bold" Foreground="#8E44AD" Margin="0"/>
                        </StackPanel>
                        <DataGrid x:Name="dgSoferi" DockPanel.Dock="Top"
                                  SelectionChanged="DgSoferi_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding IdAngajat}" Width="70"/>
                                <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="100"/>
                                <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusCurent}" Width="90"/>
                                <DataGridTextColumn Header="Atestate" Binding="{Binding Atestate}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════
                 PANEL 4: GESTIONARE CURSE
                 ══════════════════════════════════════════════ -->
            <Grid x:Name="panelCurse" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" MinWidth="260"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Form creare cursa -->
                <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="12" Padding="16">
                    <Border.Effect><DropShadowEffect BlurRadius="18" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Gestionare Curse" FontSize="17" FontWeight="Bold"
                                       Foreground="#F1F5F9" Margin="0,0,0,12"/>

                            <Label x:Name="lblCursaPlecare" Content="Punct Plecare:"/>
                            <TextBox x:Name="txtCursaPlecare"/>

                            <Label x:Name="lblCursaDestinatie" Content="Destinație:"/>
                            <TextBox x:Name="txtCursaDestinatie"/>

                            <Label x:Name="lblCursaDistanta" Content="Distanță (km):"/>
                            <TextBox x:Name="txtCursaDistanta"/>

                            <Label Content="ETA (ex: 2h30m):"/>
                            <TextBox x:Name="txtCursaETA"/>

                            <Label x:Name="lblCursaPret" Content="Preț (RON):"/>
                            <TextBox x:Name="txtCursaPret"/>

                            <Label x:Name="lblCursaCamion" Content="Camion Alocat:"/>
                            <ComboBox x:Name="cmbCursaCamion"
                                      DisplayMemberPath="NumarInmatriculare"/>

                            <Label x:Name="lblCursaSofer" Content="Șofer Alocat:"/>
                            <ComboBox x:Name="cmbCursaSofer"
                                      DisplayMemberPath="IdAngajat"/>

                            <GroupBox Header="Cerințe Marfă">
                                <StackPanel Margin="4">
                                    <CheckBox x:Name="chkCursaFragil" Content="Fragil" Margin="0,2"/>
                                    <CheckBox x:Name="chkCursaADR" Content="Periculos ADR" Margin="0,2"/>
                                    <CheckBox x:Name="chkCursaTemp" Content="Sensibil Temperatură" Margin="0,2"/>
                                    <CheckBox x:Name="chkCursaAnimale" Content="Animale Vii" Margin="0,2"/>
                                </StackPanel>
                            </GroupBox>

                            <TextBlock x:Name="lblMesajCursa" TextWrapping="Wrap"
                                       Margin="0,4" FontWeight="SemiBold"/>

                            <Button Content="➕  Adaugă Cursă" Click="BtnAdaugaCursa_Click"/>

                            <Separator Margin="0,8" Background="#4C4C7A"/>
                            <TextBlock Text="Acțiuni pe Cursa Selectată" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#A78BFA" Margin="0,0,0,6"/>

                            <Button Content="▶  Începe Cursa" Click="BtnIncepeCursa_Click"
                                    Background="#2563EB"/>
                            <Button Content="✔  Finalizează Cursa" Click="BtnFinalizeazaCursa_Click"
                                    Background="#16A34A" Margin="0,4"/>
                            <Button Content="✖  Anulează Cursa" Click="BtnAnuleazaCursa_Click"
                                    Background="#DC2626" Margin="0,4"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- DataGrid Curse -->
                <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="12" Padding="16">
                    <Border.Effect><DropShadowEffect BlurRadius="18" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="Listă Curse" FontSize="17" FontWeight="Bold"
                                       Foreground="#F1F5F9" Margin="0,0,0,6"/>
                            <Label Content="{Binding ElementName=dgCurse,
                                                     Path=Items.Count,
                                                     StringFormat='Număr curse: {0}'}"
                                   FontWeight="Bold" Foreground="#F59E0B" Margin="0"/>
                        </StackPanel>
                        <DataGrid x:Name="dgCurse" DockPanel.Dock="Top"
                                  SelectionChanged="DgCurse_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Plecare" Binding="{Binding PunctPlecare}" Width="100"/>
                                <DataGridTextColumn Header="Destinație" Binding="{Binding Destinatie}" Width="100"/>
                                <DataGridTextColumn Header="Km" Binding="{Binding DistantaKm}" Width="55"/>
                                <DataGridTextColumn Header="ETA" Binding="{Binding ETA}" Width="65"/>
                                <DataGridTextColumn Header="Preț" Binding="{Binding Pret, StringFormat='{}{0:N0} RON'}" Width="80"/>
                                <DataGridTextColumn Header="Camion" Binding="{Binding CamionAlocat.NumarInmatriculare}" Width="90"/>
                                <DataGridTextColumn Header="Șofer" Binding="{Binding SoferAlocat.IdAngajat}" Width="70"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
